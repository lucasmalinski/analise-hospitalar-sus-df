model Model
	culture: en-GB
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["fato_atendimento","dim_data","dim_estabelecimento","dim_procedimento","dim_diagnostico","dim_municipio_residencia","dim_ra_residencia","dim_detalhes","_Medidas","URL Base"]

annotation PBI_ProTooling = ["DevMode"]

ref table fato_atendimento
ref table dim_data
ref table dim_estabelecimento
ref table dim_procedimento
ref table dim_municipio_residencia
ref table dim_ra_residencia
ref table dim_detalhes
ref table dim_diagnostico
ref table _Medidas
ref table 'URL Base'

ref role 'Presidente / Mesa Diretora CSDF'
ref role 'Camara Tecnica Regional - Central'
ref role 'Camara Tecnica Regional - Centro-Sul'
ref role 'Camara Tecnica Regional - Leste'
ref role 'Camara Tecnica Regional - Norte'
ref role 'Camara Tecnica Regional - Oeste'
ref role 'Camara Tecnica Regional - Sudoeste'
ref role 'Camara Tecnica Regional - Sul'
ref role 'Conselheiro Regional - Plano Piloto'

ref cultureInfo en-GB

