{
  "name": "Hospital SUS-DF — CSDF",
  "dataColors": [
    "#000055",
    "#000080",
    "#0000AA",
    "#0000D4",
    "#838483",
    "#4040FF",
    "#008888",
    "#610287"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F2937",
  "tableAccent": "#0E7C7B",
  "good": "#0E7C7B",
  "neutral": "#6B7280",
  "bad": "#C7185A",
  "maximum": "#0E7C7B",
  "center": "#E89A3C",
  "minimum": "#C7185A",
  "null": "#E5E7EB",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI",
      "fontSize": 22,
      "color": "#1F2937"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#374151"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#6B7280"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 36,
      "color": "#0E7C7B"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 6
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "fontSize": 14,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "legend": [
          {
            "labelColor": {
              "solid": {
                "color": "#374151"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 8
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#0E7C7B"
              }
            },
            "fontSize": 36,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "gauge": {
      "*": {
        "dataColors": [
          {
            "fill": {
              "solid": {
                "color": "#0E7C7B"
              }
            },
            "target": {
              "solid": {
                "color": "#1F2937"
              }
            }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "lineStyles": [
          {
            "strokeWidth": 3
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "labels": [
          {
            "show": true,
            "labelStyle": "Both"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F9FAFB"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}